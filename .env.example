# Used by the browser app (safe to expose, protected by Row Level Security)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Used for admin operations (creating/resetting user accounts).
# Keep this secret — only admins access these features in the app.
VITE_SUPABASE_SERVICE_ROLE_KEY=

# Server-side only: used for running SQL migrations (psql / Supabase CLI).
# NEVER expose this in client code or commit a real value.
DATABASE_URL=
